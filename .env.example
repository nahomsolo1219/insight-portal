# Copy this file to `.env.local` and fill in real values from Supabase.
# Never commit `.env.local` — it's gitignored.

# ----------------------------------------------------------------------------
# Supabase (URL + keys)
# ----------------------------------------------------------------------------

# Project URL — visible in the Supabase dashboard under Settings → API.
# Public; safe to expose in the browser bundle.
NEXT_PUBLIC_SUPABASE_URL="https://YOUR_PROJECT_REF.supabase.co"

# Anon key — public key the browser uses with RLS. NOT a secret.
NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJ..."

# Service-role key — bypasses RLS. SECRET. Used only by Server Actions
# that explicitly need it (invite flow, ZIP downloads, manual storage ops).
# Do NOT expose to the browser.
SUPABASE_SERVICE_ROLE_KEY="eyJ..."

# ----------------------------------------------------------------------------
# Postgres connection strings
# ----------------------------------------------------------------------------

# Pooled connection on port 6543 (transaction-mode pooler). Used by the
# Next.js runtime app via Drizzle. Short-lived queries; the runtime
# benefits from the default 2-minute statement_timeout as a safety net.
DATABASE_URL="postgresql://postgres.PROJECT_REF:PASSWORD@aws-1-REGION.pooler.supabase.com:6543/postgres"

# Session pooler on port 5432. Used by drizzle-kit for migrations and
# by helper scripts in `scripts/`. Falls back to this if
# MIGRATION_DATABASE_URL is unset.
DIRECT_URL="postgresql://postgres.PROJECT_REF:PASSWORD@aws-1-REGION.pooler.supabase.com:5432/postgres"

# Optional: dedicated migration connection. If your migrations need a
# longer statement_timeout than the role's default, set this to a
# non-pooled connection AND append the timeout override:
#   ?options=-c%20statement_timeout%3D0
# (URL-encoded form of `-c statement_timeout=0`.)
#
# IMPORTANT: as of 2026-04, Supabase's pooler at *.pooler.supabase.com
# silently drops the `options` startup parameter, so this URL trick has
# no effect on pooled connections. Use the manual-apply script
# (`npm run db:migrate:manual`) for migrations that exceed the role's
# 2-minute timeout, or move this URL to the truly direct
# `db.PROJECT_REF.supabase.co:5432` endpoint where startup params are
# honoured. See `docs/MIGRATIONS.md` for the full SOP.
# MIGRATION_DATABASE_URL=""

# ----------------------------------------------------------------------------
# Application
# ----------------------------------------------------------------------------

# Origin used to build magic-link callback URLs. Set per environment —
# http://localhost:3000 locally, the Vercel deployment URL in
# preview/prod.
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
